            <div class="product-meta"><div class="rating"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="far fa-star"></i><span>4.6</span></div><span class="price">RWF 39,000</span></div>
            <a href="product-herbal-glow.html" class="btn-cart"><i class="fas fa-eye"></i> View Product</a>
