  <link rel="stylesheet" href="css/sections.css" />
  <link rel="icon" type="image/svg+xml" href="/isoko-life-center/favicon.svg" />
  <style>
    .product-detail { padding: 60px 0 90px; background: var(--white); }
    .product-detail-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
    .product-visual { position: relative; }
    .product-big-img { height: 420px; background: linear-gradient(145deg, #C89A58, #8A6030); border-radius: var(--radius-lg); display: flex; align-items: center; justify-content: center; font-size: 6rem; color: rgba(255,255,255,0.85); }
    .product-badge-large { position: absolute; top: 20px; left: 20px; background: var(--green); color: var(--white); padding: 6px 16px; border-radius: 3px; font-size: 0.72rem; font-weight: 500; letter-spacing: 0.09em; text-transform: uppercase; }
    .product-thumbs { display: flex; gap: 10px; margin-top: 14px; }
    .product-thumb { width: 72px; height: 72px; background: linear-gradient(145deg, #C89A58, #8A6030); border-radius: var(--radius); display: flex; align-items: center; justify-content: center; font-size: 1.4rem; color: rgba(255,255,255,0.8); cursor: pointer; border: 2px solid transparent; transition: var(--transition); opacity: 0.6; }
    .product-thumb.active { border-color: var(--green); opacity: 1; }
    .product-info h1 { font-size: 2.4rem; margin-bottom: 0.5rem; }
    .product-cat-tag { display: inline-block; background: var(--green-wash); color: var(--green); border: 1px solid var(--green-pale); padding: 4px 14px; border-radius: 40px; font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 500; margin-bottom: 1rem; }
    .product-rating-row { display: flex; align-items: center; gap: 12px; margin-bottom: 1.5rem; }
    .product-rating-row .rating { color: var(--gold); font-size: 0.9rem; display: flex; align-items: center; gap: 3px; }
    .product-rating-row span { font-size: 0.85rem; color: var(--ink-soft); }
    .product-price-row { display: flex; align-items: baseline; gap: 1rem; margin-bottom: 1.5rem; }
    .product-price-big { font-family: 'Cormorant Garamond', serif; font-size: 2.2rem; font-weight: 600; color: var(--ink); }
    .product-desc { font-size: 0.95rem; color: var(--ink-soft); line-height: 1.85; margin-bottom: 2rem; }
    .product-highlights { margin-bottom: 2rem; }
    .product-highlights h4 { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--ink-soft); margin-bottom: 1rem; font-weight: 500; }
    .highlight-item { display: flex; align-items: center; gap: 10px; margin-bottom: 0.7rem; font-size: 0.88rem; color: var(--ink-mid); }
    .highlight-item i { color: var(--green); font-size: 0.85rem; width: 16px; }
    .qty-row { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem; }
    .qty-label { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--ink-soft); font-weight: 500; }
    .qty-control { display: flex; align-items: center; border: 1px solid var(--cream-dark); border-radius: var(--radius); overflow: hidden; }
    .qty-btn { width: 38px; height: 38px; background: var(--cream); border: none; cursor: pointer; font-size: 1rem; color: var(--ink-mid); transition: var(--transition); }
    .qty-btn:hover { background: var(--green-wash); color: var(--green); }
    .qty-num { width: 44px; height: 38px; display: flex; align-items: center; justify-content: center; font-size: 0.9rem; font-weight: 500; color: var(--ink); border-left: 1px solid var(--cream-dark); border-right: 1px solid var(--cream-dark); }
    .btn-add-large { width: 100%; background: var(--green); color: var(--white); border: none; padding: 15px; border-radius: var(--radius); cursor: pointer; font-family: 'Jost', sans-serif; font-size: 0.9rem; font-weight: 500; letter-spacing: 0.07em; display: flex; align-items: center; justify-content: center; gap: 10px; transition: var(--transition); margin-bottom: 12px; }
    .btn-add-large:hover { background: var(--green-mid); transform: translateY(-1px); }
    .btn-consult-link { width: 100%; background: transparent; color: var(--green); border: 1px solid var(--green); padding: 13px; border-radius: var(--radius); cursor: pointer; font-family: 'Jost', sans-serif; font-size: 0.88rem; letter-spacing: 0.06em; display: flex; align-items: center; justify-content: center; gap: 10px; text-decoration: none; transition: var(--transition); }
    .btn-consult-link:hover { background: var(--green-wash); }
    .product-tabs { margin-top: 4rem; border-top: 1px solid var(--cream-dark); padding-top: 3rem; }
    .tab-nav { display: flex; gap: 0; margin-bottom: 2rem; border-bottom: 1px solid var(--cream-dark); }
    .tab-btn { padding: 10px 24px; background: none; border: none; border-bottom: 2px solid transparent; cursor: pointer; font-family: 'Jost', sans-serif; font-size: 0.82rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-soft); transition: var(--transition); margin-bottom: -1px; }
    .tab-btn.active { color: var(--green); border-bottom-color: var(--green); }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }
    .tab-panel p { font-size: 0.92rem; color: var(--ink-soft); line-height: 1.85; margin-bottom: 1rem; }
    .tab-panel ul { list-style: none; padding: 0; }
    .tab-panel ul li { font-size: 0.92rem; color: var(--ink-soft); padding: 8px 0; border-bottom: 1px solid var(--cream-dark); display: flex; gap: 10px; }
    .tab-panel ul li i { color: var(--green); margin-top: 2px; flex-shrink: 0; }
    .related-section { padding: 60px 0 90px; background: var(--cream); }
    .breadcrumb { padding: 16px 0; }
    .breadcrumb a { color: var(--ink-soft); text-decoration: none; font-size: 0.82rem; }
    .breadcrumb a:hover { color: var(--green); }
    .breadcrumb span { color: var(--ink-soft); font-size: 0.82rem; margin: 0 8px; }
    .breadcrumb strong { font-size: 0.82rem; color: var(--ink-mid); font-weight: 400; }
    @media (max-width: 860px) { .product-detail-inner { grid-template-columns: 1fr; gap: 2.5rem; } }
  </style>
</head>
<body>

  <div id="site-header"></div>

  <div class="container">
    <nav class="breadcrumb">
      <a href="index.html">Home</a><span>/</span>
