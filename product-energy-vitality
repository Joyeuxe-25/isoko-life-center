          <div class="product-highlights">
            <h4>Key Benefits</h4>
            <div class="highlight-item"><i class="fas fa-check"></i> Sustained energy without crashes</div>
            <div class="highlight-item"><i class="fas fa-check"></i> Reduces fatigue and tiredness</div>
            <div class="highlight-item"><i class="fas fa-check"></i> Supports physical and mental performance</div>
            <div class="highlight-item"><i class="fas fa-check"></i> Natural herbal formula</div>
            <div class="highlight-item"><i class="fas fa-check"></i> No caffeine or stimulants</div>
          </div>

          <div class="qty-row">
            <span class="qty-label">Quantity</span>
            <div class="qty-control">
              <button class="qty-btn" onclick="changeQty(-1)">−</button>
              <div class="qty-num" id="qty">1</div>
              <button class="qty-btn" onclick="changeQty(1)">+</button>
