            <div class="product-meta"><div class="rating"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i><span>4.7</span></div><span class="price">RWF 33,000</span></div>
            <a href="product-massage-oil.html" class="btn-cart"><i class="fas fa-eye"></i> View Product</a>
